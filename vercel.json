{
  "version": 2,
  "name": "sb-public-site",
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "framework": "create-react-app",
  "rewrites": [
    {
      "source": "/api/data",
      "destination": "/api/data.js"
    },
    {
      "source": "/api/submit",
      "destination": "/api/submit.js"
    },
    {
      "source": "/api/file",
      "destination": "/api/file.js"
    },
    {
      "source": "/api/search",
      "destination": "/api/search.js"
    },
    {
      "source": "/api/analytics",
      "destination": "/api/analytics.js"
    },
    {
      "source": "/api/rate-limit",
      "destination": "/api/rate-limit.js"
    },
    {
      "source": "/api/image-optimize",
      "destination": "/api/image-optimize.js"
    },
    {
      "source": "/api/pdf-preview",
      "destination": "/api/pdf-preview.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type, Authorization"
        }
      ]
    }
  ]
}
